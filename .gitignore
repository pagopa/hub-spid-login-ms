# .gitignore — reorganized and commented
# Logical grouping of ignores: Terraform, Node/Yarn, build,
# generated code, certificates/credentials, editor, lint, and Docker.

# --- Terraform ---
# Local working directories and state files created by Terraform
**/.terraform/*
*.tfstate
*.tfstate.*

# --- Node / Build ---
# Local dependencies and build artifacts
node_modules/
dist/
yarn-error.log

# Yarn 4 (Corepack): ignore the .yarn folder but keep subfolders
# that must be committed (patches/plugins/releases/sdks/versions)
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions

# Yarn for the `e2e` workspace (same behavior as above)
e2e/.yarn/*
!e2e/.yarn/patches
!e2e/.yarn/plugins
!e2e/.yarn/releases
!e2e/.yarn/sdks
!e2e/.yarn/versions

# --- Coverage & Report ---
# Test results and generated reports
coverage/

# --- Generated code ---
# API clients and other autogenerated artifacts
generated/

# --- Certificates, keys and sensitive files ---
# Do not commit local keys, certificates, or environment files
certs/
.env
jwt_rsa_key.pem
jwt_rsa_public.pem
idp.crt
idp.key
sp_metadata.xml
temp

# --- Editor / IDE ---
# Editor-specific settings that should not be shared
.vscode/settings.json
.idea

# --- ESLint ---
# Keep the config file, ignore the cache
!.eslintrc.js
.eslintcache

# --- Docker / Local override ---
# Local override files for Docker Compose
docker-compose.override.yml
